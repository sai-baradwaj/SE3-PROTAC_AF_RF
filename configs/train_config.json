{
  "_comment": "SE3AF v4.0 Training Config — scaffold-split data, improved generalization",
  "_note": "v4.0 CHANGES: scaffold split (0% overlap), proper coord fallback (no random coords), protein geometry encoder (af_extra_dim=16), UTF-8 encoding fixes",
  "_version": "4.0.0",

  "backend": "se3",

  "epochs": 100,
  "batch_size": 8,
  "learning_rate": 2e-4,
  "weight_decay": 5e-4,
  "grad_clip": 1.0,
  "warmup_epochs": 5,
  "seed": 42,
  "grad_accum_steps": 4,

  "focal_gamma": 2.0,
  "focal_alpha": 0.5,
  "stability_loss_weight": 0.25,
  "interaction_loss_weight": 0.25,
  "ssl_loss_weight": 0.0,
  "contrastive_loss_weight": 0.0,
  "label_smoothing": 0.10,
  "label_smoothing_end": 0.03,

  "dropout": 0.35,
  "ema_decay": 0.999,
  "use_ema": true,
  "stochastic_depth_p": 0.18,
  "feature_noise_std": 0.05,
  "mixup_alpha": 0.4,

  "use_smiles_augment": true,
  "smiles_augment_p": 0.5,
  "use_coord_jitter": true,
  "coord_jitter_std": 0.10,

  "use_swa": false,
  "swa_start_fraction": 0.75,
  "swa_lr": 5e-5,

  "use_coords": true,

  "val_fraction": 0.15,
  "test_fraction": 0.10,
  "num_workers": 2,
  "pin_memory": false,

  "checkpoint_dir": "checkpoints",
  "save_every_n_epochs": 5,
  "keep_last_n": 3,
  "early_stop_patience": 25,
  "early_stop_metric": "auroc",
  "early_stop_mode": "max",
  "overfit_window": 3,

  "use_amp": false,
  "amp_dtype": "bfloat16",

  "fusion_dim": 128,
  "esm_dim": 1280,
  "graph_hidden": 128,
  "num_graph_layers": 4,
  "num_heads": 4,
  "num_rbf": 16,
  "cutoff": 8.0,

  "use_masked_graph": false,
  "use_contrastive": false,
  "ssl_pretrain_epochs": 0,

  "use_rf_stacker": true,
  "rf_n_estimators": 300,
  "rf_fp_bits": 2048,
  "rf_max_depth": 10,

  "alphafold_dir": "data/alphafold",
  "af_extra_dim": 16,

  "use_goss": true,
  "goss_top_k": 6,

  "training_mode": "fresh"
}
